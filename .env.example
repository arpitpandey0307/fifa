# ============================================================================
# FIFA Nexus AI — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================================

# =============
# REQUIRED
# =============

# Google Gemini API Key — powers all AI features
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# =============
# OPTIONAL
# =============

# Port (defaults to 3000 for dev, 8080 for Cloud Run)
# PORT=3000

# Node environment
# NODE_ENV=development
